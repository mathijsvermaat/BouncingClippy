# Azure AI Foundry Configuration for Semantic Kernel
# Copy this file to .env and fill in your actual values

# Your Azure AI Foundry endpoint URL (without /inference suffix)
# Example: https://your-project.eastus.services.ai.azure.com
AZURE_AI_FOUNDRY_ENDPOINT=https://"CHANGE".services.ai.azure.com
AZURE_AI_FOUNDRY_MODEL=gpt-4o
FLASK_DEBUG=False
